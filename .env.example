# ── Telegram ──────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Public HTTPS URL where this server is hosted (no trailing slash)
# For production, use a stable HTTPS domain (do not use temporary ngrok URLs)
# For local dev use ngrok: https://xxxx.ngrok.io
WEBHOOK_URL=https://your-domain.com

# Telegram group ID where admins review payments (negative number, e.g. -1001234567890)
ADMIN_GROUP_ID=-1001234567890

# Private supergroup/channel ID for generating VIP invite links (negative number)
VIP_CHANNEL_ID=-1001234567891

# Bundle pack channel link sent after approval (e.g. https://t.me/your_paid_channel)
VIP_INVITE_LINK_PAID=https://t.me/your_paid_channel

# Comma-separated Telegram user IDs of admins who can approve/reject
ADMIN_IDS=123456789,987654321

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Use service role key (server-side only, never expose to client)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── KBZPay ────────────────────────────────────────────────
KBZPAY_PHONE=09-XXX-XXXXXXX
KBZPAY_NAME=Your Name

# ── App Settings ──────────────────────────────────────────
PORT=8000
# Enable unique amount offset (true/false)
USE_UNIQUE_AMOUNT=true
# Max screenshot file size in bytes (default 5MB)
MAX_FILE_SIZE=5242880

# ── Concurrency / Performance ─────────────────────────────
# Redis is recommended in production for shared session state across workers/instances.
# Leave empty to use in-memory sessions (single-instance only).
REDIS_URL=redis://localhost:6379/0

# Number of background workers processing Telegram updates from the webhook queue.
# Recommended start: 8
UPDATE_WORKERS=8

# Max queued webhook updates before returning 503 (Telegram will retry).
# Recommended start: 1000
UPDATE_QUEUE_SIZE=1000

# Admin review time estimate shown to users (in hours)
ADMIN_REVIEW_TIME_HOURS=1
